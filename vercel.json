{
  "functions": {
    "api/scan-code.js": { "maxDuration": 10 }
  },
  "redirects": [
    {
      "source": "/play-report",
      "destination": "/debrief/",
      "permanent": true
    },
    {
      "source": "/play-report/",
      "destination": "/debrief/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/stream/alerts",
      "destination": "/stream/alerts/index.html"
    },
    {
      "source": "/stream/alerts/",
      "destination": "/stream/alerts/index.html"
    },
    {
      "source": "/stream/alerts/fx",
      "destination": "/stream/alerts/fx/index.html"
    },
    {
      "source": "/stream/alerts/fx/",
      "destination": "/stream/alerts/fx/index.html"
    },
    {
      "source": "/stream/sigilforge/glyph-static",
      "destination": "/stream/sigilforge/glyph-static/index.html"
    },
    {
      "source": "/stream/sigilforge/glyph-static/",
      "destination": "/stream/sigilforge/glyph-static/index.html"
    },
    {
      "source": "/stream/sigilforge/cam-frame",
      "destination": "/stream/sigilforge/cam-frame/index.html"
    },
    {
      "source": "/stream/sigilforge/cam-frame/",
      "destination": "/stream/sigilforge/cam-frame/index.html"
    },
    {
      "source": "/debrief",
      "destination": "/debrief/index.html"
    },
    {
      "source": "/debrief/",
      "destination": "/debrief/index.html"
    },
    {
      "source": "/recovered-operator-reports",
      "destination": "/recovered-operator-reports/index.html"
    },
    {
      "source": "/recovered-operator-reports/",
      "destination": "/recovered-operator-reports/index.html"
    },
    {
      "source": "/admin/alerts",
      "destination": "/admin/alerts/index.html"
    },
    {
      "source": "/admin/alerts/",
      "destination": "/admin/alerts/index.html"
    },
    {
      "source": "/admin/conversion",
      "destination": "/admin/conversion/index.html"
    },
    {
      "source": "/admin/conversion/",
      "destination": "/admin/conversion/index.html"
    },
    {
      "source": "/admin/reports",
      "destination": "/admin/reports/index.html"
    },
    {
      "source": "/admin/reports/",
      "destination": "/admin/reports/index.html"
    }
  ],
  "headers": [
    {
      "source": "/stream/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    }
  ]
}
