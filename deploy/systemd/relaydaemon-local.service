[Unit]
Description=RelayDaemon local Ollama bridge
After=network.target ollama.service

[Service]
Type=simple
WorkingDirectory=/home/nox/projects/veildaemon
ExecStart=/usr/bin/node /home/nox/projects/veildaemon/scripts/relay-local-bridge.mjs
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
